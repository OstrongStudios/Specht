<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Specht.App.Pages.DeviceDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Specht.App.ViewModels"
    xmlns:loc="using:Specht.App.Localization">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header with back -->
        <Grid Grid.Row="0" Padding="8,8,12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" ToolTipService.ToolTip="{loc:Translate Key=DetailBackButton.ToolTip}" Click="OnBack" Background="Transparent" BorderBrush="Transparent">
                <FontIcon Glyph="&#xE72B;" />
            </Button>
            <FontIcon Grid.Column="1" Glyph="{x:Bind ViewModel.CategoryGlyph, Mode=OneWay}" FontSize="24" VerticalAlignment="Center" />
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="4,0,0,0">
                <TextBlock Text="{x:Bind ViewModel.DisplayName, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock Text="{x:Bind ViewModel.CategoryLabel, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
            </StackPanel>
            <Button Grid.Column="3" ToolTipService.ToolTip="{loc:Translate Key=DetailCopyJsonButton.ToolTip}" Command="{x:Bind ViewModel.CopyAsJsonCommand}">
                <FontIcon Glyph="&#xE8C8;" />
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="16,0,16,16">
            <StackPanel Spacing="16">

                <!-- Connection -->
                <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Translate Key=DetailConnectionHeader.Text}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <Grid ColumnSpacing="8" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Translate Key=DetailLabelIpv4.Text}" Opacity="0.7" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.IPv4Text, Mode=OneWay}" TextWrapping="Wrap" FontFamily="Consolas" />
                        <Button Grid.Row="0" Grid.Column="2" Command="{x:Bind ViewModel.CopyIPv4Command}" Padding="6,2" Background="Transparent" BorderBrush="Transparent">
                            <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                        </Button>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Translate Key=DetailLabelIpv6.Text}" Opacity="0.7" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.IPv6Text, Mode=OneWay}" TextWrapping="Wrap" FontFamily="Consolas" />
                        <Button Grid.Row="1" Grid.Column="2" Command="{x:Bind ViewModel.CopyIPv6Command}" Padding="6,2" Background="Transparent" BorderBrush="Transparent">
                            <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                        </Button>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Translate Key=DetailLabelPort.Text}" Opacity="0.7" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.PortText, Mode=OneWay}" FontFamily="Consolas" />
                        <Button Grid.Row="2" Grid.Column="2" Command="{x:Bind ViewModel.CopyPortCommand}" Padding="6,2" Background="Transparent" BorderBrush="Transparent">
                            <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                        </Button>
                    </Grid>

                    <!-- Source adapters -->
                    <Grid ColumnSpacing="8" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Translate Key=DetailLabelSource.Text}" Opacity="0.7" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SourceAdaptersText, Mode=OneWay}" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>

                <!-- Identity -->
                <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Translate Key=DetailIdentityHeader.Text}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <Grid ColumnSpacing="8" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Translate Key=DetailLabelHostname.Text}" Opacity="0.7" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.HostnameText, Mode=OneWay}" TextWrapping="Wrap" FontFamily="Consolas" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Translate Key=DetailLabelService.Text}" Opacity="0.7" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.ServiceTypeText, Mode=OneWay}" TextWrapping="Wrap" FontFamily="Consolas" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Translate Key=DetailLabelInstance.Text}" Opacity="0.7" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.InstanceNameText, Mode=OneWay}" TextWrapping="Wrap" FontFamily="Consolas" />
                    </Grid>
                </StackPanel>

                <!-- TXT records -->
                <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Translate Key=DetailTxtHeader.Text}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.TxtEntries, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TxtEntry">
                                <Grid ColumnSpacing="8" Padding="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Key}" FontFamily="Consolas" Opacity="0.7" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Value}" FontFamily="Consolas" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                                    <FontIcon Grid.Column="2"
                                              Glyph="&#xE7BA;"
                                              FontSize="12"
                                              Foreground="{ThemeResource SystemAccentColorLight2}"
                                              ToolTipService.ToolTip="{loc:Translate Key=DetailTxtBinaryTip}"
                                              Visibility="{x:Bind BinaryIndicator}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{loc:Translate Key=DetailNoTxt.Text}" Opacity="0.5" Visibility="{x:Bind ViewModel.NoTxtVisibility, Mode=OneWay}" />
                </StackPanel>

                <!-- Activity -->
                <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Translate Key=DetailActivityHeader.Text}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <Grid ColumnSpacing="8" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Translate Key=DetailLabelFirstSeen.Text}" Opacity="0.7" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.FirstSeenText, Mode=OneWay}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Translate Key=DetailLabelLastSeen.Text}" Opacity="0.7" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.LastSeenText, Mode=OneWay}" />
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
