<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Specht.App.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Specht.App.ViewModels"
    xmlns:conv="using:Specht.App.Converters"
    xmlns:loc="using:Specht.App.Localization">

    <Page.Resources>
        <conv:IsNewToBrushConverter x:Key="IsNewToBrush" />
        <conv:InverseBoolToOpacityConverter x:Key="LeavingToOpacity" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                Grid.Column="0"
                PlaceholderText="{loc:Translate Key=SearchBox.PlaceholderText}"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="1" ToolTipService.ToolTip="{loc:Translate Key=RefreshButton.ToolTip}" Command="{x:Bind ViewModel.RefreshCommand}">
                <FontIcon Glyph="&#xE72C;" />
            </Button>
            <Button Grid.Column="2" ToolTipService.ToolTip="{loc:Translate Key=MoreButton.ToolTip}">
                <FontIcon Glyph="&#xE712;" />
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="{loc:Translate Key=MenuExportCsv.Text}" Click="OnExportCsvClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74E;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{loc:Translate Key=MenuExportJson.Text}" Click="OnExportJsonClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE943;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="{loc:Translate Key=MenuSettings.Text}" Click="OnSettingsClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE713;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{loc:Translate Key=MenuAbout.Text}" Click="OnAboutClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE946;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="{loc:Translate Key=MenuExit.Text}" Click="OnExitClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE7E8;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <!-- Filter chips: 2 rows, all visible without scrolling -->
        <Grid Grid.Row="1" Padding="12,0,12,8" ColumnSpacing="6" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ToggleButton Grid.Row="0" Grid.Column="0" x:Name="ChipAll"      Tag="All"       Content="{loc:Translate Key=FilterAll.Text}" Click="OnChipClick" IsChecked="True" HorizontalAlignment="Stretch" />
            <ToggleButton Grid.Row="0" Grid.Column="1" x:Name="ChipAirPlay"  Tag="AirPlay"   Content="AirPlay"   Click="OnChipClick" HorizontalAlignment="Stretch" />
            <ToggleButton Grid.Row="0" Grid.Column="2" x:Name="ChipCast"     Tag="Cast"      Content="Cast"      Click="OnChipClick" HorizontalAlignment="Stretch" />
            <ToggleButton Grid.Row="0" Grid.Column="3" x:Name="ChipAudio"    Tag="Audio"     Content="Audio"     Click="OnChipClick" HorizontalAlignment="Stretch" />

            <ToggleButton Grid.Row="1" Grid.Column="0" x:Name="ChipPrint"    Tag="Print"     Content="Print"     Click="OnChipClick" HorizontalAlignment="Stretch" />
            <ToggleButton Grid.Row="1" Grid.Column="1" x:Name="ChipHomeKit"  Tag="HomeKit"   Content="HomeKit"   Click="OnChipClick" HorizontalAlignment="Stretch" />
            <ToggleButton Grid.Row="1" Grid.Column="2" x:Name="ChipFileShare" Tag="FileShare" Content="FileShare" Click="OnChipClick" HorizontalAlignment="Stretch" />
            <ToggleButton Grid.Row="1" Grid.Column="3" x:Name="ChipIoT"      Tag="IoT"       Content="IoT"       Click="OnChipClick" HorizontalAlignment="Stretch" />
        </Grid>

        <!-- Empty state -->
        <StackPanel Grid.Row="2"
                    Visibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="8" Padding="32" MaxWidth="320">
            <FontIcon Glyph="{x:Bind ViewModel.EmptyGlyph, Mode=OneWay}" FontSize="40" Opacity="0.6" HorizontalAlignment="Center" />
            <TextBlock Text="{x:Bind ViewModel.EmptyHeader, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" TextAlignment="Center" TextWrapping="Wrap" />
            <TextBlock Text="{x:Bind ViewModel.EmptyDetail, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" TextAlignment="Center" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Device list -->
        <ListView
            Grid.Row="2"
            x:Name="DeviceList"
            Visibility="{x:Bind ViewModel.ListVisibility, Mode=OneWay}"
            ItemsSource="{x:Bind ViewModel.FilteredDevices, Mode=OneWay}"
            SelectionMode="Single"
            IsItemClickEnabled="True"
            ItemClick="OnDeviceClick"
            Padding="8,0">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:DeviceViewModel">
                    <Border BorderThickness="2" CornerRadius="6"
                            BorderBrush="{x:Bind IsNew, Mode=OneWay, Converter={StaticResource IsNewToBrush}}"
                            Opacity="{x:Bind IsLeaving, Mode=OneWay, Converter={StaticResource LeavingToOpacity}}">
                        <Border.OpacityTransition>
                            <ScalarTransition Duration="0:0:0.6" />
                        </Border.OpacityTransition>
                        <Grid Padding="8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="{x:Bind CategoryGlyph}" FontSize="20" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{x:Bind DisplayName}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{x:Bind Subtitle}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
                            </StackPanel>
                            <Border Grid.Column="2" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind CategoryLabel}" Style="{ThemeResource CaptionTextBlockStyle}" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status bar -->
        <Border Grid.Row="3" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <TextBlock
                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                Padding="12,6"
                Style="{ThemeResource CaptionTextBlockStyle}" />
        </Border>
    </Grid>
</Page>
