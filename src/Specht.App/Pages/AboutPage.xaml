<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Specht.App.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:Specht.App.Localization">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="8,8,12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" ToolTipService.ToolTip="{loc:Translate Key=AboutBackButton.ToolTip}" Click="OnBack" Background="Transparent" BorderBrush="Transparent">
                <FontIcon Glyph="&#xE72B;" />
            </Button>
            <TextBlock Grid.Column="1" Text="{loc:Translate Key=AboutTitle.Text}" Style="{ThemeResource SubtitleTextBlockStyle}" VerticalAlignment="Center" Margin="4,0,0,0" />
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="16,8,16,16">
            <StackPanel Spacing="16">

                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <Image Source="ms-appx:///Assets/StoreLogo.scale-200.png" Width="100" Height="100" />
                    <TextBlock Text="Specht" Style="{ThemeResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Bind VersionText, Mode=OneTime}" Opacity="0.7" HorizontalAlignment="Center" />
                    <TextBlock Text="{loc:Translate Key=AboutTagline.Text}" FontStyle="Italic" Opacity="0.7" HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Translate Key=AboutPublisherHeader.Text}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="Ostrong Studios" />
                    <HyperlinkButton Content="www.ostrongstudios.de" NavigateUri="https://www.ostrongstudios.de" Padding="0" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Translate Key=AboutLicenseHeader.Text}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{loc:Translate Key=AboutLicenseText.Text}" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Translate Key=AboutThirdPartyHeader.Text}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="• Makaretu.Dns.Multicast.New (MIT)" Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock Text="• H.NotifyIcon.WinUI (MIT)" Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock Text="• CommunityToolkit.Mvvm (MIT)" Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock Text="• Microsoft Windows App SDK / WinUI 3 (MIT)" Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock Text="• .NET 10 (MIT)" Style="{ThemeResource CaptionTextBlockStyle}" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Translate Key=AboutTrademarksHeader.Text}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{loc:Translate Key=AboutTrademarksText.Text}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
